#!/bin/bash
set -e

# Brewfile hash: {{ includeTemplate "Brewfile.tmpl" . | sha256sum }}

echo "==> Installing packages via Homebrew..."

# Detect OS and architecture
OS="$(uname -s)"
ARCH="$(uname -m)"

# Configure Homebrew prefix
if [ "$OS" = "Darwin" ]; then
    [ "$ARCH" = "arm64" ] && HOMEBREW_PREFIX="/opt/homebrew" || HOMEBREW_PREFIX="/usr/local"
else
    HOMEBREW_PREFIX="/home/linuxbrew/.linuxbrew"
fi

# Install Homebrew if not present
if ! command -v brew &> /dev/null; then
    echo "==> Installing Homebrew..."
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$($HOMEBREW_PREFIX/bin/brew shellenv)"
fi

# Ensure brew is in PATH
eval "$($HOMEBREW_PREFIX/bin/brew shellenv)"

# Render Brewfile template and install packages
BREWFILE_TMP="$(mktemp)"
cat > "$BREWFILE_TMP" << 'BREWFILE_EOF'
{{ includeTemplate "Brewfile.tmpl" . }}
BREWFILE_EOF

brew bundle --file="$BREWFILE_TMP"
rm -f "$BREWFILE_TMP"

echo "==> Packages installed successfully!"
